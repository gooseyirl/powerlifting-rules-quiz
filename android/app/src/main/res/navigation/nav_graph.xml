<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.gooseco.technicalrulesquiz.ui.home.HomeFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_quiz_setup"
            app:destination="@id/quizSetupFragment"
            app:enterAnim="@android:anim/slide_in_left"
            app:exitAnim="@android:anim/slide_out_right"
            app:popEnterAnim="@android:anim/slide_in_left"
            app:popExitAnim="@android:anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/quizSetupFragment"
        android:name="com.gooseco.technicalrulesquiz.ui.home.QuizSetupFragment"
        android:label="@string/choose_quiz_length"
        tools:layout="@layout/fragment_quiz_setup">
        <action
            android:id="@+id/action_quiz_setup_to_quiz"
            app:destination="@id/quizFragment"
            app:enterAnim="@android:anim/slide_in_left"
            app:exitAnim="@android:anim/slide_out_right"
            app:popEnterAnim="@android:anim/slide_in_left"
            app:popExitAnim="@android:anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.gooseco.technicalrulesquiz.ui.quiz.QuizFragment"
        android:label="Quiz"
        tools:layout="@layout/fragment_quiz">
        <argument
            android:name="questionCount"
            app:argType="integer"
            android:defaultValue="10" />
        <action
            android:id="@+id/action_quiz_to_result"
            app:destination="@id/resultFragment"
            app:popUpTo="@id/homeFragment"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/resultFragment"
        android:name="com.gooseco.technicalrulesquiz.ui.result.ResultFragment"
        android:label="Results"
        tools:layout="@layout/fragment_result">
        <action
            android:id="@+id/action_result_to_review"
            app:destination="@id/reviewFragment"
            app:enterAnim="@android:anim/slide_in_left"
            app:exitAnim="@android:anim/slide_out_right"
            app:popEnterAnim="@android:anim/slide_in_left"
            app:popExitAnim="@android:anim/slide_out_right" />
        <action
            android:id="@+id/action_result_to_quiz"
            app:destination="@id/quizFragment"
            app:popUpTo="@id/resultFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_result_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/reviewFragment"
        android:name="com.gooseco.technicalrulesquiz.ui.review.ReviewFragment"
        android:label="@string/review_answers"
        tools:layout="@layout/fragment_review">
        <action
            android:id="@+id/action_review_to_pdf"
            app:destination="@id/pdfViewerFragment"
            app:enterAnim="@android:anim/slide_in_left"
            app:exitAnim="@android:anim/slide_out_right"
            app:popEnterAnim="@android:anim/slide_in_left"
            app:popExitAnim="@android:anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/pdfViewerFragment"
        android:name="com.gooseco.technicalrulesquiz.ui.pdf.PdfViewerFragment"
        android:label="@string/ipf_rulebook"
        tools:layout="@layout/fragment_pdf_viewer">
        <argument
            android:name="pageNumber"
            app:argType="integer"
            android:defaultValue="1" />
    </fragment>

</navigation>
